{
  "name": "shelfcheck",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "BASENAME=/ react-router dev",
    "typecheck": "react-router typegen && tsc",
    "lint": "oxlint app/",
    "fmt": "oxfmt --write app/ *.ts",
    "fmt:check": "oxfmt --check app/ *.ts",
    "knip": "knip",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:update-snapshots": "vitest run --update",
    "test": "npm run fmt:check && npm run lint && npm run typecheck && npm run test:unit && npm run knip && npm run build",
    "publish:lexicons": "node --experimental-strip-types scripts/publish-lexicons.ts"
  },
  "dependencies": {
    "@atproto/api": "^0.19.9",
    "@atproto/oauth-client-browser": "^0.3.41",
    "@posthog/react": "^1.9.0",
    "@react-router/node": "7.14.0",
    "isbot": "^5",
    "posthog-js": "^1.367.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.4.1",
    "msw": "^2.13.5",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.4",
    "vitest-browser-react": "^2.2.0"
  }
}
